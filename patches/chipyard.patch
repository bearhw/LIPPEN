+// lalit: simple foo_bar for clang
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <stdint.h>  // For uintptr_t
+#include <inttypes.h>
+#include "hpm.h"
+#include "pac_customx.h"
+
+int foo(int a) {
+    prince_set_key(0x0011223344556677, 0x8899AABBCCDDEEFF);
+    uintptr_t bulshit = prince_sign((uintptr_t)&foo, 16);
+    uintptr_t signed_pointer = prince_sign((uintptr_t)&foo, 16);	
+    printf("I am PAC-foo\n");
+    printf("[foo] &foo       = %p\n", (void*)&foo);
+    printf("  signed_ptr = 0x%016" PRIxPTR "\n", signed_pointer);
+    uintptr_t res = prince_auth(signed_pointer, 16);
+    printf("  auth_res   = 0x%016" PRIxPTR "\n", res);
+    return a * 2;
+}
+
+int bar(int b) {
+    prince_set_key(0x0011223344556675, 0x8899AABBCCDDEEF3);
+    uintptr_t signed_pointer = prince_sign((uintptr_t)&bar, 8778);	
+    printf(" I am PAC-bar\n");	
+    printf("[bar] &bar       = %p\n", (void*)&bar);
+    printf("  signed_ptr = 0x%016" PRIxPTR "\n", signed_pointer);
+    prince_set_key(0x0011223344556675, 0x8899AABBCCDDEE23);
+    uintptr_t res = prince_auth(signed_pointer, 8778);
+    printf("  auth_res   = 0x%016" PRIxPTR "\n", res);
+    return b + 1;
+}
+
+int main() {
+    int x = 5;
+    int y = foo(x);
+    int z = bar(y);
+
+    return 0;
+}
