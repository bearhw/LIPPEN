+// -----------------------------------------------------------------------------
+// Single-entry ready/valid pipeline register (active-low reset)
+// -----------------------------------------------------------------------------
+module register_stage
+#(
+  parameter WIDTH = 64,
+  parameter REGISTERED = 1
+)(
+  input  wire                  clk,
+  input  wire                  resetn,     // active-low
+  input  wire [WIDTH-1:0]      in_data,
+  input  wire                  in_valid,
+  output wire                  in_ready,
+  output wire [WIDTH-1:0]      out_data,
+  output wire                  out_valid,
+  input  wire                  out_ready
+);
+
+  generate if (REGISTERED) begin : g_reg
+    reg [WIDTH-1:0] data_r;
+    reg             valid_r;
+
+    assign in_ready  = (~valid_r) | (out_ready & valid_r);
+    assign out_valid = valid_r;
+    assign out_data  = data_r;
+
+    always @(posedge clk or negedge resetn) begin
+      if (!resetn) begin
+        valid_r <= 1'b0;
+      end else begin
+        if (in_ready) begin
+          valid_r <= in_valid;
+          if (in_valid)
+            data_r <= in_data;
+        end
+      end
+    end
+  end else begin : g_unreg
+    assign in_ready  = out_ready;
+    assign out_valid = in_valid;
+    assign out_data  = in_data;
+  end endgenerate
+
+endmodule
+
+// -----------------------------------------------------------------------------
+// QARMA (ROUNDS fixed to 7) — runtime enc/dec via enc_dec input (1=ENC, 0=DEC)
+// -----------------------------------------------------------------------------
+module qarma
+(
+  input  wire         ClkxCI,
+  input  wire         RstxRBI,        // active-low reset
+  input  wire         enc_dec,        // 1 = encrypt, 0 = decrypt
+  input  wire [127:0] KeyxDI,
+  input  wire [63:0]  TweakxDI,
+  input  wire [63:0]  MessagexDI,
+  output wire [63:0]  CiphertextxDO,
+
+  output wire         in_ready,
+  input  wire         in_valid,
+  input  wire         out_ready,
+  output wire         out_valid
+);
+
+  // ---------------------------------------------------------------------------
+  // Constants & tables (match VHDL)
+  // ---------------------------------------------------------------------------
+  localparam [63:0] AlphaxD = 64'hc0ac_29b7_c97c_50dd;
+
+  function [63:0] RC;
+    input integer idx;
+    begin
+      case (idx)
+        0: RC = 64'h0000_0000_0000_0000;
+        1: RC = 64'h1319_8a2e_0370_7344;
+        2: RC = 64'ha409_3822_299f_31d0;
+        3: RC = 64'h082e_fa98_ec4e_6c89;
+        4: RC = 64'h4528_21e6_38d0_1377;
+        5: RC = 64'hbe54_66cf_34e9_0c6c;
+        6: RC = 64'h3f84_d5b5_b547_0917;
+        7: RC = 64'h9216_d5d9_8979_fb1b;
+        default: RC = 64'h0;
+      endcase
+    end
+  endfunction
+
+  // Permutations as integer-returning functions (same as VHDL arrays)
+  function integer perm_tau_val; input integer i; begin
+    case (i)
+      0:  perm_tau_val = 0;
+      1:  perm_tau_val = 11;
+      2:  perm_tau_val = 6;
+      3:  perm_tau_val = 13;
+      4:  perm_tau_val = 10;
+      5:  perm_tau_val = 1;
+      6:  perm_tau_val = 12;
+      7:  perm_tau_val = 7;
+      8:  perm_tau_val = 5;
+      9:  perm_tau_val = 14;
+      10: perm_tau_val = 3;
+      11: perm_tau_val = 8;
+      12: perm_tau_val = 15;
+      13: perm_tau_val = 4;
+      14: perm_tau_val = 9;
+      15: perm_tau_val = 2;
+      default: perm_tau_val = 0;
+    endcase
+  end endfunction
+
+  function integer perm_tau_inv_val; input integer i; begin
+    case (i)
+      0:  perm_tau_inv_val = 0;
+      1:  perm_tau_inv_val = 5;
+      2:  perm_tau_inv_val = 15;
+      3:  perm_tau_inv_val = 10;
+      4:  perm_tau_inv_val = 13;
+      5:  perm_tau_inv_val = 8;
+      6:  perm_tau_inv_val = 2;
+      7:  perm_tau_inv_val = 7;
+      8:  perm_tau_inv_val = 11;
+      9:  perm_tau_inv_val = 14;
+      10: perm_tau_inv_val = 4;
+      11: perm_tau_inv_val = 1;
+      12: perm_tau_inv_val = 6;
+      13: perm_tau_inv_val = 3;
+      14: perm_tau_inv_val = 9;
+      15: perm_tau_inv_val = 12;
+      default: perm_tau_inv_val = 0;
+    endcase
+  end endfunction
+
+  function integer perm_h_val; input integer i; begin
+    case (i)
+      0:  perm_h_val = 6;
+      1:  perm_h_val = 5;
+      2:  perm_h_val = 14;
+      3:  perm_h_val = 15;
+      4:  perm_h_val = 0;
+      5:  perm_h_val = 1;
+      6:  perm_h_val = 2;
+      7:  perm_h_val = 3;
+      8:  perm_h_val = 7;
+      9:  perm_h_val = 12;
+      10: perm_h_val = 13;
+      11: perm_h_val = 4;
+      12: perm_h_val = 8;
+      13: perm_h_val = 9;
+      14: perm_h_val = 10;
+      15: perm_h_val = 11;
+      default: perm_h_val = 0;
+    endcase
+  end endfunction
+
+  function integer perm_h_inv_val; input integer i; begin
+    case (i)
+      0:  perm_h_inv_val = 4;
+      1:  perm_h_inv_val = 5;
+      2:  perm_h_inv_val = 6;
+      3:  perm_h_inv_val = 7;
+      4:  perm_h_inv_val = 11;
+      5:  perm_h_inv_val = 1;
+      6:  perm_h_inv_val = 0;
+      7:  perm_h_inv_val = 8;
+      8:  perm_h_inv_val = 12;
+      9:  perm_h_inv_val = 13;
+      10: perm_h_inv_val = 14;
+      11: perm_h_inv_val = 15;
+      12: perm_h_inv_val = 9;
+      13: perm_h_inv_val = 10;
+      14: perm_h_inv_val = 2;
+      15: perm_h_inv_val = 3;
+      default: perm_h_inv_val = 0;
+    endcase
+  end endfunction
+
+  // Sigma1 S-box (and inverse – involution in VHDL)
+  function [3:0] sbox_sigma1; input [3:0] x; begin
+    case (x)
+      4'h0: sbox_sigma1 = 4'hA; 4'h1: sbox_sigma1 = 4'hD; 4'h2: sbox_sigma1 = 4'hE; 4'h3: sbox_sigma1 = 4'h6;
+      4'h4: sbox_sigma1 = 4'hF; 4'h5: sbox_sigma1 = 4'h7; 4'h6: sbox_sigma1 = 4'h3; 4'h7: sbox_sigma1 = 4'h5;
+      4'h8: sbox_sigma1 = 4'h9; 4'h9: sbox_sigma1 = 4'h8; 4'hA: sbox_sigma1 = 4'h0; 4'hB: sbox_sigma1 = 4'hC;
+      4'hC: sbox_sigma1 = 4'hB; 4'hD: sbox_sigma1 = 4'h1; 4'hE: sbox_sigma1 = 4'h2; 4'hF: sbox_sigma1 = 4'h4;
+    endcase
+  end endfunction
+
+  // Helpers
+  function [3:0] ROTATE_LEFT4; input [3:0] v; input integer rot; begin
+    case (rot)
+      1: ROTATE_LEFT4 = {v[2:0], v[3]};
+      2: ROTATE_LEFT4 = {v[1:0], v[3:2]};
+      3: ROTATE_LEFT4 = {v[0], v[3:1]};
+      default: ROTATE_LEFT4 = v;
+    endcase
+  end endfunction
+
+  function [3:0] LFSR_nibble; input [3:0] inx; begin
+    // Out[2:0] = in[3:1]; Out[3] = in[0] ^ in[1]
+    LFSR_nibble = { (inx[0] ^ inx[1]), inx[3:1] };
+  end endfunction
+
+  function [63:0] LFSR_OMEGA; input [63:0] x; reg [63:0] y; begin
+    y = x;
+    y[63:60] = LFSR_nibble(x[63:60]); // 0
+    y[59:56] = LFSR_nibble(x[59:56]); // 1
+    y[51:48] = LFSR_nibble(x[51:48]); // 3
+    y[47:44] = LFSR_nibble(x[47:44]); // 4
+    y[31:28] = LFSR_nibble(x[31:28]); // 8
+    y[19:16] = LFSR_nibble(x[19:16]); // 11
+    y[11:8]  = LFSR_nibble(x[11:8]);  // 13
+    LFSR_OMEGA = y;
+  end endfunction
+
+  function [63:0] FUNC_O; input [63:0] inx; reg [63:0] outx; begin
+    outx    = {inx[0], inx[63:1]};
+    outx[0] = outx[0] ^ inx[63];
+    FUNC_O  = outx;
+  end endfunction
+
+  function [63:0] SUB_CELLS; input [63:0] s; integer i; reg [63:0] r; begin
+    r = 64'b0;
+    for (i = 0; i < 16; i = i + 1)
+      r[i*4 +: 4] = sbox_sigma1(s[i*4 +: 4]);
+    SUB_CELLS = r;
+  end endfunction
+
+  function [63:0] INV_SUB_CELLS; input [63:0] s; begin
+    INV_SUB_CELLS = SUB_CELLS(s); // involution
+  end endfunction
+
+  // General permutation apply (dest = 15-i; src = 15-Perm(i))
+  function [63:0] PERM_APPLY;
+    input [63:0] s;
+    input integer sel; // 0:Tau, 1:TauInv, 2:H, 3:HInv
+    integer i, index_dest, index_src;
+    reg [63:0] r;
+    begin
+      r = 64'b0;
+      for (i = 0; i < 16; i = i + 1) begin
+        index_dest = 15 - i;
+        case (sel)
+          0: index_src = 15 - perm_tau_val(i);
+          1: index_src = 15 - perm_tau_inv_val(i);
+          2: index_src = 15 - perm_h_val(i);
+          default: index_src = 15 - perm_h_inv_val(i);
+        endcase
+        r[index_dest*4 +: 4] = s[index_src*4 +: 4];
+      end
+      PERM_APPLY = r;
+    end
+  endfunction
+
+  function [63:0] SHUFFLE_CELLS;     input [63:0] s; begin SHUFFLE_CELLS     = PERM_APPLY(s, 0); end endfunction
+  function [63:0] INV_SHUFFLE_CELLS; input [63:0] s; begin INV_SHUFFLE_CELLS = PERM_APPLY(s, 1); end endfunction
+  function [63:0] PERMUTATION_H;     input [63:0] s; begin PERMUTATION_H     = PERM_APPLY(s, 2); end endfunction
+  function [63:0] PERMUTATION_H_INV; input [63:0] s; begin PERMUTATION_H_INV = PERM_APPLY(s, 3); end endfunction
+
+  function [15:0] MULTIPLY_M4_2; input [15:0] inx;
+    reg [3:0] n3,n2,n1,n0, o3,o2,o1,o0;
+    begin
+      n3 = inx[15:12]; n2 = inx[11:8]; n1 = inx[7:4]; n0 = inx[3:0];
+      o3 = ROTATE_LEFT4(n2,1) ^ ROTATE_LEFT4(n1,2) ^ ROTATE_LEFT4(n0,1);
+      o2 = ROTATE_LEFT4(n3,1) ^ ROTATE_LEFT4(n1,1) ^ ROTATE_LEFT4(n0,2);
+      o1 = ROTATE_LEFT4(n3,2) ^ ROTATE_LEFT4(n2,1) ^ ROTATE_LEFT4(n0,1);
+      o0 = ROTATE_LEFT4(n3,1) ^ ROTATE_LEFT4(n2,2) ^ ROTATE_LEFT4(n1,1);
+      MULTIPLY_M4_2 = {o3,o2,o1,o0};
+    end
+  endfunction
+
+  function [63:0] MIX_COLUMNS; input [63:0] s;
+    integer i, idx3,idx2,idx1,idx0;
+    reg [63:0] r;
+    reg [15:0] col_in, col_out;
+    begin
+      r = s;
+      for (i = 0; i < 4; i = i + 1) begin
+        idx3 = 12 + i; idx2 = 8 + i; idx1 = 4 + i; idx0 = 0 + i;
+        col_in  = { s[idx3*4 +: 4], s[idx2*4 +: 4], s[idx1*4 +: 4], s[idx0*4 +: 4] };
+        col_out = MULTIPLY_M4_2(col_in);
+        r[idx3*4 +: 4] = col_out[15:12];
+        r[idx2*4 +: 4] = col_out[11:8];
+        r[idx1*4 +: 4] = col_out[7:4];
+        r[idx0*4 +: 4] = col_out[3:0];
+      end
+      MIX_COLUMNS = r;
+    end
+  endfunction
+
+  function [63:0] ROUND; input [63:0] st, tk;
+    reg [63:0] addx, shufx, mixx;
+    begin
+      addx  = st ^ tk;
+      shufx = SHUFFLE_CELLS(addx);
+      mixx  = MIX_COLUMNS(shufx);
+      ROUND = SUB_CELLS(mixx);
+    end
+  endfunction
+
+  function [63:0] ROUND_SHORT; input [63:0] st, tk; begin
+    ROUND_SHORT = SUB_CELLS(st ^ tk);
+  end endfunction
+
+  function [63:0] ROUND_INV; input [63:0] st, tk;
+    reg [63:0] subx, mixx, shufx;
+    begin
+      subx    = INV_SUB_CELLS(st);
+      mixx    = MIX_COLUMNS(subx);
+      shufx   = INV_SHUFFLE_CELLS(mixx);
+      ROUND_INV = shufx ^ tk;
+    end
+  endfunction
+
+  function [63:0] ROUND_INV_SHORT; input [63:0] st, tk; begin
+    ROUND_INV_SHORT = INV_SUB_CELLS(st) ^ tk;
+  end endfunction
+
+  function [63:0] PSEUDO_REFLECTOR; input [63:0] st, tk;
+    reg [63:0] shufx, mixx, addx;
+    begin
+      shufx  = SHUFFLE_CELLS(st);
+      mixx   = MIX_COLUMNS(shufx);
+      addx   = mixx ^ tk;
+      PSEUDO_REFLECTOR = INV_SHUFFLE_CELLS(addx);
+    end
+  endfunction
+
+  // ---------------------------------------------------------------------------
+  // Runtime key "properties" from enc_dec (matches VHDL generate choices)
+  // enc_dec = 1 (ENC): W0=Key[127:64],    W1=FUNC_O(W0),   K0=Key[63:0],     K1=K0
+  // enc_dec = 0 (DEC): W1=Key[127:64],    W0=FUNC_O(W1),   K0=Key[63:0]^A,   K1=MIX_COLUMNS(Key[63:0])
+  // ---------------------------------------------------------------------------
+  wire [63:0] W0xD = enc_dec ?              KeyxDI[127:64] : FUNC_O(KeyxDI[127:64]);
+  wire [63:0] W1xD = enc_dec ? FUNC_O(      KeyxDI[127:64]) :       KeyxDI[127:64];
+  wire [63:0] K0xD = enc_dec ?              KeyxDI[63:0]    : (KeyxDI[63:0] ^ AlphaxD);
+  wire [63:0] K1xD = enc_dec ?                          K0xD :  MIX_COLUMNS(KeyxDI[63:0]);
+
+  // ---------------------------------------------------------------------------
+  // Unrolled chain for ROUNDS = 7 (0..7)
+  // ---------------------------------------------------------------------------
+  wire [63:0] State0_0, State0_1, State0_2, State0_3, State0_4, State0_5, State0_6, State0_7;
+  wire [63:0] Tweak_0,  Tweak_1,  Tweak_2,  Tweak_3,  Tweak_4,  Tweak_5,  Tweak_6,  Tweak_7;
+
+  assign State0_0 = MessagexDI ^ W0xD;
+  assign Tweak_0  = TweakxDI;
+
+  assign State0_1 = ROUND_SHORT(State0_0, K0xD ^ Tweak_0 ^ RC(0));
+  assign Tweak_1  = LFSR_OMEGA(PERMUTATION_H(Tweak_0));
+
+  assign State0_2 = ROUND(State0_1, K0xD ^ Tweak_1 ^ RC(1));
+  assign Tweak_2  = LFSR_OMEGA(PERMUTATION_H(Tweak_1));
+
+  assign State0_3 = ROUND(State0_2, K0xD ^ Tweak_2 ^ RC(2));
+  assign Tweak_3  = LFSR_OMEGA(PERMUTATION_H(Tweak_2));
+
+  assign State0_4 = ROUND(State0_3, K0xD ^ Tweak_3 ^ RC(3));
+  assign Tweak_4  = LFSR_OMEGA(PERMUTATION_H(Tweak_3));
+
+  assign State0_5 = ROUND(State0_4, K0xD ^ Tweak_4 ^ RC(4));
+  assign Tweak_5  = LFSR_OMEGA(PERMUTATION_H(Tweak_4));
+
+  assign State0_6 = ROUND(State0_5, K0xD ^ Tweak_5 ^ RC(5));
+  assign Tweak_6  = LFSR_OMEGA(PERMUTATION_H(Tweak_5));
+
+  assign State0_7 = ROUND(State0_6, K0xD ^ Tweak_6 ^ RC(6));
+  assign Tweak_7  = LFSR_OMEGA(PERMUTATION_H(Tweak_6));
+
+  // Middle and reflector
+  wire [63:0] StateMiddle0xD = ROUND(State0_7, W1xD ^ Tweak_7);
+  wire [63:0] StateMiddle1xD = PSEUDO_REFLECTOR(StateMiddle0xD, K1xD);
+
+  // Pipeline register (ready/valid)
+  wire [63:0] RegisterInxD      = StateMiddle1xD;
+  wire        RegisterInValidxS = in_valid;
+  wire        RegisterInReadyxS;
+  assign      in_ready = RegisterInReadyxS;
+
+  wire [63:0] RegisterOutxD;
+  wire        RegisterOutValidxS;
+  wire        RegisterOutReadyxS = out_ready;
+  assign      out_valid = RegisterOutValidxS;
+
+  register_stage #(.WIDTH(64), .REGISTERED(1)) u_reg (
+    .clk      (ClkxCI),
+    .resetn   (RstxRBI),
+    .in_data  (RegisterInxD),
+    .in_valid (RegisterInValidxS),
+    .in_ready (RegisterInReadyxS),
+    .out_data (RegisterOutxD),
+    .out_valid(RegisterOutValidxS),
+    .out_ready(RegisterOutReadyxS)
+  );
+
+  // Second half (inverse rounds), ROUNDS = 7
+  wire [63:0] State1_0, State1_1, State1_2, State1_3, State1_4, State1_5, State1_6;
+  assign State1_0 = ROUND_INV(RegisterOutxD, W0xD ^ Tweak_7);
+
+  assign State1_1 = ROUND_INV(State1_0, K0xD ^ Tweak_6 ^ RC(6) ^ AlphaxD);
+  assign State1_2 = ROUND_INV(State1_1, K0xD ^ Tweak_5 ^ RC(5) ^ AlphaxD);
+  assign State1_3 = ROUND_INV(State1_2, K0xD ^ Tweak_4 ^ RC(4) ^ AlphaxD);
+  assign State1_4 = ROUND_INV(State1_3, K0xD ^ Tweak_3 ^ RC(3) ^ AlphaxD);
+  assign State1_5 = ROUND_INV(State1_4, K0xD ^ Tweak_2 ^ RC(2) ^ AlphaxD);
+  assign State1_6 = ROUND_INV(State1_5, K0xD ^ Tweak_1 ^ RC(1) ^ AlphaxD);
+
+  // Final short inverse round and output
+  wire [63:0] State1_last = ROUND_INV_SHORT(State1_6, K0xD ^ Tweak_0 ^ RC(0) ^ AlphaxD);
+
+  assign CiphertextxDO = State1_last ^ W1xD;
+
+endmodule
diff --git a/generators/chipyard/src/main/resources/vsrc/qarma_erfan.v b/generators/chipyard/src/main/resources/vsrc/qarma_erfan.v
