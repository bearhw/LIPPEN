+class PAQarmaENCImp(outer: PAQarmaENC)(implicit p: Parameters)
+  extends LazyRoCCModuleImp(outer) with HasCoreParameters {
+
+  // Funct 0: Auth (decrypt path in your terminology)
+  // Funct 1: Sign  (encrypt path)
+  // Funct 2: Set Key
+  val cmd   = Queue(io.cmd)
+  val funct = cmd.bits.inst.funct
+  val rd    = cmd.bits.inst.rd
+
+  val pointer  = cmd.bits.rs1
+  val modifier = cmd.bits.rs2  // we will use this as the 64-bit tweak
+
+  // Key register
+  val keyRegister = RegInit(BigInt("FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF", 16).U(128.W))
+
+  // Fields from pointer
+  val ptr        = pointer(47, 0)
+  val topPtr     = pointer(63, 48)
+  val cleanedPtr = Cat(0.U(16.W), ptr) // zero top16
+
+  // Ops
+  val isAuth      = funct === 0.U
+  val isSign      = funct === 1.U
+  val isSetKey    = funct === 2.U
+  val needsCrypto = !isSetKey
+
+  // BlackBox with tweak port
+  val q = Module(new QarmaCipherWrap)
+  q.io.clk := clock
+  q.io.rst := reset.asBool
+
+  // Always run with d=1 (authentication mode per your request)
+  q.io.d     := true.B
+  q.io.inp   := cleanedPtr
+  q.io.key   := keyRegister
+  q.io.tweak := modifier  // NEW: drive tweak from rs2
+
+  // In-flight bookkeeping (latch op kind and metadata)
+  val inflight    = RegInit(false.B)
+  val rdReg       = Reg(UInt(5.W))
+  val topPtrReg   = Reg(UInt(16.W))
+  val ptrReg      = Reg(UInt(48.W))
+  val doRespReg   = RegInit(false.B)
+  val opIsAuthReg = RegInit(false.B)
+
+  // Issue handshake
+  val canIssueCrypto = cmd.valid && needsCrypto && q.io.ready_out
+  q.io.valid_in := canIssueCrypto
+
+  when (canIssueCrypto) {
+    inflight    := true.B
+    rdReg       := rd
+    topPtrReg   := topPtr
+    ptrReg      := ptr
+    doRespReg   := cmd.bits.inst.xd
+    opIsAuthReg := isAuth
+  }
+
+  // Set-key (no crypto pipeline)
+  when (cmd.valid && isSetKey) {
+    keyRegister := Cat(pointer(63, 0), modifier(63, 0))
+  }
+
+  // Build response from latched metadata
+  val qarmaOut          = q.io.out.asUInt
+  val pac               = qarmaOut(15, 0)
+  val signedPtr64       = Cat(pac, ptrReg)
+  val cleanedPtrLatched = Cat(0.U(16.W), ptrReg)
+  val authMatches       = topPtrReg === pac
+  val authFail64        = "hFFFFFFFFFFFFFFFF".U(64.W)
+
+  val cryptoRespData =
+    Mux(opIsAuthReg,
+      Mux(authMatches, cleanedPtrLatched, authFail64),  // AUTH
+      signedPtr64)                                      // SIGN
+
+  // Let the stage drain even if xd=0; respect resp.ready if xd=1
+  q.io.ready_in := Mux(inflight, (io.resp.ready || !doRespReg), true.B)
+
+  // Command ready policy
+  val doResp      = cmd.bits.inst.xd
+  val setKeyFires = cmd.valid && isSetKey && (!doResp || io.resp.ready)
+  val cryptoFires = q.io.valid_out && q.io.ready_in
+
+  when (cryptoFires) { inflight := false.B }
+
+  cmd.ready := setKeyFires || (cmd.valid && needsCrypto && q.io.ready_out)
+
+  // Response channel
+  val respValidSetKey = setKeyFires && doResp
+  val respValidCrypto = q.io.valid_out && inflight && doRespReg
+
+  io.resp.valid     := respValidSetKey || respValidCrypto
+  io.resp.bits.rd   := Mux(respValidSetKey, rd, rdReg)
+  io.resp.bits.data := Mux(respValidSetKey, pointer, cryptoRespData)
+
+  // Busy & interrupt
+  io.busy      := cmd.valid || inflight || q.io.valid_out
+  io.interrupt := false.B
+}
+
+
+
+
+
+
+
+
+
+
+class PAQarmaImp(outer: PAQarma)(implicit p: Parameters)
+  extends LazyRoCCModuleImp(outer) with HasCoreParameters {
+
+  // Ingress
+  val cmd   = Queue(io.cmd)
+  val funct = cmd.bits.inst.funct
+  val rd    = cmd.bits.inst.rd
+
+  val rs1 = cmd.bits.rs1
+  val rs2 = cmd.bits.rs2
+
+  val pointer  = rs1
+  val modifier = rs2 // tweak
+
+  // 128-bit key; default all 1s
+  val keyRegister = RegInit("hFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF".U(128.W))
+
+  // Pointer fields
+  val ptr48      = pointer(47, 0)
+  val top16      = pointer(63, 48)
+  val cleanedPtr = Cat(0.U(16.W), ptr48)
+
+  // Ops
+  val isAuth   = funct === 0.U
+  val isSign   = funct === 1.U
+  val isSetKey = funct === 2.U
+
+  // Cipher core (treated as purely combinational; ignore ready/valid)
+  val q = Module(new QarmaCipherWrap_erfan)
+  q.io.clk := clock
+  q.io.rst := reset.asBool
+
+  // keep your setting (even if the comment is confusing)
+  q.io.d     := true.B
+  q.io.inp   := cleanedPtr
+  q.io.key   := keyRegister
+  q.io.tweak := modifier
+
+  // Do NOT use these handshake signals (core doesn't implement them)
+  q.io.valid_in := false.B
+  q.io.ready_in := true.B
+
+  // Key programming (funct=2)
+  when (cmd.valid && isSetKey) {
+    keyRegister := Cat(pointer(63, 0), modifier(63, 0))
+  }
+
+  // Build response data from combinational cipher output + current cmd bits
+  val qarmaOut    = q.io.out.asUInt
+  val pac16       = qarmaOut(15, 0)
+  val signedPtr64 = Cat(pac16, ptr48)
+
+  val authMatches = top16 === pac16
+  val authFail64  = "hFFFFFFFFFFFFFFFF".U(64.W)
+
+  val cryptoRespData =
+    Mux(isAuth,
+      Mux(authMatches, cleanedPtr, authFail64), // AUTH
+      signedPtr64                               // SIGN
+    )
+
+  val respData =
+    Mux(isSetKey, pointer, cryptoRespData) // set-key -> echo pointer (your old behavior)
+
+  // Handshake (Prince-style)
+  val doResp    = cmd.bits.inst.xd
+  val stallResp = doResp && !io.resp.ready
+
+  // IMPORTANT: ready must not depend on cmd.valid in a way that creates loops.
+  // This is BOOM-safe and matches your working module.
+  cmd.ready         := !stallResp
+  io.resp.valid     := cmd.valid && doResp
+  io.resp.bits.rd   := rd
+  io.resp.bits.data := respData
+
+  // Status (BOOM-safe)
+  io.busy      := cmd.valid && stallResp
+  io.interrupt := false.B
+
+}
