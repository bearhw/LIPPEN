+class PAPrinceV2Enc(opcodes: OpcodeSet)(implicit p: Parameters)
+  extends LazyRoCC(opcodes = opcodes, nPTWPorts = 0) {
+  override lazy val module = new PAPrinceV2EncImp(this)
+}
+
+// -----------------------------------------------------------------------------
+// Module implementation
+// Funct 0: Decrypt & authenticate (cmp top16 vs rs2[15:0])
+// Funct 1: Encrypt/sign (pack rs2[15:0] || rs1[47:0])
+// Funct 2: Set 128-bit key using {rs1, rs2}
