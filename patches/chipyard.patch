new file mode 100644
index 00000000..a2d442df
--- /dev/null
+++ b/tests/pac_customx.h
@@ -0,0 +1,113 @@
+//-------------------------------------------------------------
+// lalit: ROCC CustomX header
+//-------------------------------------------------------------
+/*
+// //   --- ROCC MACRO used in Dec'24 ----------
+// #define STR1(x) #x
+// #define STR(x) STR1(x)
+// #define EXTRACT(a, size, offset) (((~(~0 << size) << offset) & a) >> offset)
+// 
+// #define CUSTOMX_OPCODE(x) CUSTOM_ ## x
+// #define CUSTOM_3 0b1111011
+// 
+// #define CUSTOMX(X, xd, xs1, xs2, rd, rs1, rs2, funct) \
+//   CUSTOMX_OPCODE(X)                     |             \
+//   (rd                 << (7))           |             \
+//   (xs2                << (7+5))         |             \
+//   (xs1                << (7+5+1))       |             \
+//   (xd                 << (7+5+2))       |             \
+//   (rs1                << (7+5+3))       |             \
+//   (rs2                << (7+5+3+5))     |             \
+//   (EXTRACT(funct, 7, 0) << (7+5+3+5+5))
+// 
+// #define ENCRYPT() {                           \
+//     asm volatile (                            \
+//         ".word " STR(CUSTOMX(3, 1, 1, 1, 30, 1, 30, 0)) "\n\t"  \
+//     );                                        \
+// }
+// 
+// #define DECRYPT() {                           \
+//     asm volatile (                            \
+//         ".word " STR(CUSTOMX(3, 1, 1, 1, 30, 1, 30, 1)) "\n\t"  \
+//     );                                        \
+// }
+*/
+//-------------------------------------------------------------
+#include <stdint.h> 
+#include "rocc.h"
+#define PRINCE_OPCODE 1
+// Generic RoCC Accumlator
+static inline void accum_write(int idx, unsigned long data)
+{
+	ROCC_INSTRUCTION_SS(0, data, idx, 0);
+}
+
+static inline unsigned long accum_read(int idx)
+{
+	unsigned long value;
+	ROCC_INSTRUCTION_DSS(0, value, 0, idx, 1);
+	return value;
+}
+
+static inline void accum_load(int idx, void *ptr)
+{
+	asm volatile ("fence");
+	ROCC_INSTRUCTION_SS(0, (uintptr_t) ptr, idx, 2);
+}
+
+// -----
+// Block-Cipher RoCC
+
+// PAC_SIGN: Signs a pointer with a key
+static inline uintptr_t PAC_SIGN(int key, void *data_in) {
+    uintptr_t data_out = 0;
+    // The instruction expects a pointer in uintptr_t format
+    // TODO: ROCC_INSTRUCTION_I_R_R(0, data_out, (uintptr_t) data_in, key, 0, 11, 12);
+    ROCC_INSTRUCTION_DSS(3, data_out, data_in, key, 0) 
+    return data_out;
+}
+
+// PAC_AUTH: Authenticates a signed pointer with a key
+static inline void *PAC_AUTH(int key, uintptr_t data_in) {
+    uintptr_t data_out = 0;
+    // The instruction expects a pointer in uintptr_t format
+    // TODO: ROCC_INSTRUCTION_R_R_R(0, data_out, data_in, key, 1, 10, 11, 12);
+    ROCC_INSTRUCTION_DSS(3, data_out, data_in, key, 1) 
+    return (void *) data_out;
+}
+
+static inline uintptr_t prince_sign(uintptr_t plaintext, uint64_t modifier) {
+    uintptr_t result = 0;
+    ROCC_INSTRUCTION_DSS(PRINCE_OPCODE, result, plaintext, modifier, 1);
+    return result;
+}
+
+// Decrypt a 64-bit value using the PRINCE core
+static inline uintptr_t prince_auth(uintptr_t ciphertext, uint64_t modifier) {
+    uintptr_t data_out = 0;
+    ROCC_INSTRUCTION_DSS(PRINCE_OPCODE, data_out, ciphertext, modifier, 0);
+    return data_out;
+}
+
+static inline uintptr_t prince_sign2(uintptr_t plaintext) {
+    uintptr_t result = 0;
+    ROCC_INSTRUCTION_DSS(3, result, plaintext, 0, 1);
+    return result;
+}
+
+// Decrypt a 64-bit value using the PRINCE core
+static inline uintptr_t prince_auth2(uintptr_t ciphertext) {
+    uintptr_t data_out = 0;
+    ROCC_INSTRUCTION_DSS(3, data_out, ciphertext, 0, 0);
+    return data_out;
+}
+
+// Set 128-bit encryption key using rs1 = high 64 bits, rs2 = low 64 bits
+static inline void prince_set_key(uint64_t key_hi, uint64_t key_lo) {
+    ROCC_INSTRUCTION_SS(PRINCE_OPCODE, key_hi, key_lo, 2);
+}
+
+// Set 128-bit encryption key using rs1 = high 64 bits, rs2 = low 64 bits
+static inline void prince_set_modifier(uint64_t modifier) {
+    ROCC_INSTRUCTION_SS(3, modifier, modifier, 3);
+}
