+    val clk = Input(Clock())
+    val rst = Input(Bool())
+    val d   = Input(Bool())        // 0=decrypt, 1=encrypt
+    val inp = Input(UInt(64.W))
+    val key = Input(UInt(128.W))
+    val out = Output(UInt(64.W))
+  })
+  addResource("/vsrc/sbox.v")
+  addResource("/vsrc/mixt.v")
+  addResource("/vsrc/PrinceCore.v")
+  addResource("/vsrc/PrinceCipherWrap.v")
