+//   })
+
+//   addResource("/vsrc/qarma.v")
+//   addResource("/vsrc/QarmaCipherWrap.v")
+// }
+
+class QarmaCipherWrap_erfan(implicit p: Parameters) extends BlackBox
+  with HasBlackBoxResource {
+  val io = IO(new Bundle {
+    val clk       = Input(Clock())
+    val rst       = Input(Bool())        // active-high
+
+    // ready/valid
+    val valid_in  = Input(Bool())
+    val ready_out = Output(Bool())
+    val valid_out = Output(Bool())
+    val ready_in  = Input(Bool())
+
+    // data
+    val d         = Input(Bool())        // 1=encrypt, 0=decrypt
+    val inp       = Input(UInt(64.W))
+    val key       = Input(UInt(128.W))
+    val tweak     = Input(UInt(64.W))
+    val out       = Output(UInt(64.W))
+  })
+  addResource("/vsrc/qarma_erfan.v")
+  addResource("/vsrc/QarmaCipherWrap_erfan.v")
+}
+
+// -----------------------------------------------------------------------------
+// LazyRoCC wrapper: this is what you attach via BuildRoCC in your Config
+// -----------------------------------------------------------------------------
+class PEQarma(opcodes: OpcodeSet)(implicit p: Parameters)
+  extends LazyRoCC(opcodes = opcodes, nPTWPorts = 0) {
+  override lazy val module = new PEQarmaImp(this)
+}
+
+// -----------------------------------------------------------------------------
+// Module implementation
+// Funct 0: Decrypt & authenticate (cmp top16 vs rs2[15:0])
+// Funct 1: Encrypt/sign (pack rs2[15:0] || rs1[47:0])
+// Funct 2: Set 128-bit key using {rs1, rs2}
+// -----------------------------------------------------------------------------
+class PEQarmaImp(outer: PEQarma)(implicit p: Parameters)
+  extends LazyRoCCModuleImp(outer) with HasCoreParameters {
+
+  // Funct 0: Auth (decrypt path in your terminology)
+  // Funct 1: Sign  (encrypt path)
+  // Funct 2: Set Key
+  val cmd   = Queue(io.cmd)
+  val funct = cmd.bits.inst.funct
+  val rd    = cmd.bits.inst.rd
+
+  val pointer  = cmd.bits.rs1
+  val modifier = cmd.bits.rs2  // 64-bit tweak
+
+  // Key register
+  val keyRegister = RegInit(BigInt("FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF", 16).U(128.W))
+
+  // Fields from pointer
+  val ptr        = pointer(47, 0)
+  val topPtr     = pointer(63, 48)
+  val cleanedPtr = Cat(0.U(16.W), ptr) // zero top16
+
+  // Ops
+  val isAuth      = funct === 0.U
+  val isSign      = funct === 1.U
+  val isSetKey    = funct === 2.U
+  val needsCrypto = !isSetKey
+  val doResp      = cmd.bits.inst.xd
+
+  // Combinational BlackBox (no handshake)
+  val q = Module(new QarmaCipherWrap_erfan)
+  q.io.clk := clock                    // may be unused internally
+  q.io.rst := reset.asBool             // may be unused internally
+  q.io.d     := true.B                 // always "authentication mode"
+  q.io.inp   := cleanedPtr
+  q.io.key   := keyRegister
+  q.io.tweak := modifier
+
+  // With a purely combinational q, output is available same cycle
+  val qarmaOut    = q.io.out.asUInt
+  val pac         = qarmaOut(15, 0)
+  val signedPtr64 = Cat(pac, ptr)
+  val authMatches = topPtr === pac
+  val authFail64  = "hFFFFFFFFFFFFFFFF".U(64.W)
+
+  // Build response directly from *current* command
+  val cleanedPtrNow = Cat(0.U(16.W), ptr)
+  val cryptoRespData =
+    Mux(isAuth,
+      Mux(authMatches, cleanedPtrNow, authFail64), // AUTH
+      signedPtr64)                                 // SIGN (funct==1)
+
+  // Command/response handshake for combinational stage:
+  // - If xd=0, we can always take the command (no backpressure propagation)
+  // - If xd=1, only take when resp.ready is high
+  val cmdCanFire = !doResp || io.resp.ready
+  cmd.ready := cmdCanFire
+
+  // Set-key (no crypto pipeline); update only on fire
+  when (cmd.valid && cmdCanFire && isSetKey) {
+    keyRegister := Cat(pointer(63, 0), modifier(63, 0))
+  }
+
+  // Response channel (only when xd=1)
+  io.resp.valid     := cmd.valid && doResp
+  io.resp.bits.rd   := rd
+  io.resp.bits.data := Mux(isSetKey, pointer, cryptoRespData) // set-key echoes rs1 as before
+
+  // Busy & interrupt
+  io.busy      := cmd.valid
+  io.interrupt := false.B
+
+}
