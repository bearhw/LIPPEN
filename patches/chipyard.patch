+class PAPrinceV2ModifierImp(outer: PAPrinceV2Modifier)(implicit p: Parameters)
+  extends LazyRoCCModuleImp(outer) with HasCoreParameters {
+
+  val cmd   = io.cmd
+  val funct = cmd.bits.inst.funct
+  val rs1   = cmd.bits.rs1
+  val rs2   = cmd.bits.rs2
+  val rd    = cmd.bits.inst.rd
+
+  val keyReg = RegInit("hFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF".U(128.W))
+
+  val ptr48  = rs1(47, 0)
+  val tag16  = rs2(15, 0)
+  val packed = Cat(tag16, ptr48)
+  val inp64  = Mux(funct === 1.U, packed, rs1)
+
+  val core = Module(new PrinceCipherWrap)
+  core.io.clk := clock
+  core.io.rst := reset.asBool
+  core.io.d   := funct(0)
+  core.io.inp := inp64
+  core.io.key := keyReg
+
+  when (cmd.fire && funct === 2.U) {
+    keyReg := Cat(rs1(63, 0), rs2(63, 0))
+  }
+
+  val out64    = core.io.out.asUInt
+  val decTop16 = out64(63, 48)
+  val decPtr48 = out64(47, 0)
+  val cleaned  = Cat(0.U(16.W), decPtr48)
+  val authOk   = decTop16 === tag16
+  val authFail = "hFFFFFFFFFFFFFFFF".U(64.W)
+
+  val respData =
+    Mux(funct === 2.U, rs1,
+    Mux(funct === 0.U, Mux(authOk, cleaned, authFail),
+                       out64))
+
+  // -------------------------------------------------------
+  // THE 1-CYCLE DELAY STATE MACHINE
+  // -------------------------------------------------------
+  // APPLIED FIX: Do NOT expect a response if destination is x0
+  val doResp = cmd.bits.inst.xd && (rd =/= 0.U)
+
+  // State registers to hold the response data for 1 cycle
+  val respValidReg = RegInit(false.B)
+  val respDataReg  = Reg(UInt(64.W))
+  val respRdReg    = Reg(UInt(5.W))
+
+  // SAFE: Only accept a command if we aren't holding an unacknowledged response
+  cmd.ready := !respValidReg
+
+  // State machine logic
+  when (cmd.fire && doResp) {
+    // Capture the output into registers to present in Cycle 1
+    respValidReg := true.B
+    respDataReg  := respData
+    respRdReg    := rd
+  } .elsewhen (io.resp.fire) {
+    // Response successfully accepted by BOOM
+    respValidReg := false.B
+  }
+
+  io.resp.valid     := respValidReg
+  io.resp.bits.rd   := respRdReg
+  io.resp.bits.data := respDataReg
+
+  // -------------------------------------------------------
+  // SAFE TIE-OFFS AND BUSY SIGNAL
+  // -------------------------------------------------------
+  // Tie off memory to prevent uninitialized wire FIRRTL errors
+  io.mem.req.valid := false.B
+  
+  // APPLIED FIX: Busy ONLY if we are waiting to send a response
+  io.busy      := respValidReg
+  io.interrupt := false.B
+
+  // -------------------------------------------------------
+  // HARDWARE HANG DETECTORS (For Simulation Debugging)
+  // -------------------------------------------------------
+  
+  // Trace every successful instruction to see where it stops
+  when (cmd.fire) {
+    printf("[ROCC TRACE] Accepted Command: funct=%d, xd=%d, rd=%d\n", funct, cmd.bits.inst.xd, rd)
+  }
+
+  // Detector 1: Is BOOM ignoring our response?
+  val respStallCount = RegInit(0.U(32.W))
+  when (io.resp.valid && !io.resp.ready) {
+    respStallCount := respStallCount + 1.U
+    when (respStallCount === 10000.U) {
+      printf("\n[ROCC ERROR] DEADLOCK: RoCC is holding a valid response (rd=%d), but BOOM has held resp.ready LOW for 10,000 cycles!\n", io.resp.bits.rd)
+    }
+  } .otherwise {
+    respStallCount := 0.U
+  }
+
+  // Detector 2: Is BOOM holding a command but we can't accept it?
+  val cmdStallCount = RegInit(0.U(32.W))
+  when (io.cmd.valid && !io.cmd.ready) {
+    cmdStallCount := cmdStallCount + 1.U
+    when (cmdStallCount === 10000.U) {
+      printf("\n[ROCC ERROR] DEADLOCK: BOOM has a valid command, but RoCC cmd.ready is LOW for 10,000 cycles! (respValidReg is stuck High)\n")
+    }
+  } .otherwise {
+    cmdStallCount := 0.U
+  }
+}
+
