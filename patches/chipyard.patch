+`timescale 1ns/1ps
+
+module QarmaCipherWrap (
+    input  wire         clk,
+    input  wire         rst,         // active high reset
+
+    // Handshake (input side)
+    input  wire         valid_in,
+    output wire         ready_out,
+
+    // Handshake (output side)
+    output wire         valid_out,
+    input  wire         ready_in,
+
+    // Data
+    input  wire         d,           // 1 = encryption, 0 = decryption
+    input  wire [63:0]  inp,         // standard [63:0]
+    input  wire [127:0] key,         // standard [127:0]
+    input  wire [63:0]  tweak,       // standard [63:0]
+    output wire [63:0]  out          // standard [63:0]
+);
+
+    // Core wires
+    wire        core_in_ready;
+    wire        core_out_valid;
+    wire [63:0] core_out_data;
+
+    // Active-low reset to core
+    wire resetn = ~rst;
+
+    // QARMA core (runtime enc/dec via d)
+    qarma u_qarma (
+        .ClkxCI        (clk),
+        .RstxRBI       (resetn),
+        .enc_dec       (d),
+        .KeyxDI        (key),      // no flipping
+        .TweakxDI      (tweak),    // no flipping
+        .MessagexDI    (inp),      // no flipping
+        .CiphertextxDO (core_out_data),
+        .in_ready      (core_in_ready),
+        .in_valid      (valid_in),
+        .out_ready     (ready_in),
+        .out_valid     (core_out_valid)
+    );
+
+    // Pass-through handshakes and data
+    assign ready_out = core_in_ready;
+    assign valid_out = core_out_valid;
+    assign out       = core_out_data;
+
+endmodule
