+// -----------------------------------------------------------------------------
+// LazyRoCC wrapper: this is what you attach via BuildRoCC in your Config
+// -----------------------------------------------------------------------------
+class PAPrinceV2Modifier(opcodes: OpcodeSet)(implicit p: Parameters)
+  extends LazyRoCC(opcodes = opcodes, nPTWPorts = 0) {
+  override lazy val module = new PAPrinceV2ModifierImp(this)
+}
