+class PAPrinceV2EncImp(outer: PAPrinceV2Enc)(implicit p: Parameters)
+  extends LazyRoCCModuleImp(outer) with HasCoreParameters {
+
+  // Ingress
+  val cmd    = Queue(io.cmd) // depth=2 default
+  val funct  = cmd.bits.inst.funct
+  val rs1    = cmd.bits.rs1
+  val rs2    = cmd.bits.rs2
+  val rd     = cmd.bits.inst.rd
+
+  // 128-bit key; default all 1s
+  val keyReg = RegInit("hFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF".U(128.W))
+
+  // val ptr48  = rs1(47, 0)
+  // val tag16  = rs2(15, 0)
+  // val packed = Cat(tag16, ptr48)
+  // val inp64  = Mux(funct === 1.U, packed, rs1)
+
+  // Cipher core
+  // val core = Module(new PrinceCipherWrap)
+  // core.io.clk := clock
+  // core.io.rst := reset.asBool
+  // core.io.d   := funct(0)      // 0=decrypt, 1=encrypt
+  // core.io.inp := inp64
+  // core.io.key := keyReg
+
+  // Key programming (funct=2)
+  when (funct === 2.U) {
+    keyReg := Cat(rs1(63, 0), rs2(63, 0))
+  }
+
+  // Decrypt authenticate path
+  // val out64     = core.io.out.asUInt
+  // val decTop16  = out64(63, 48)
+  // val decPtr48  = out64(47, 0)
+  // val cleaned   = Cat(0.U(16.W), decPtr48)
+  // val authOk    = decTop16 === tag16
+  // val authFail  = "hFFFFFFFFFFFFFFFF".U(64.W)
+
+  // Response mux
+  // val respData =
+  //   Mux(funct === 2.U, rs1,                       // set-key → echo rs1 // decrypt
+  //                      out64)                  // encrypt/sign
+
+  // Handshake
+  val doResp    = cmd.bits.inst.xd
+  val stallResp = doResp && !io.resp.ready
+  cmd.ready         := !stallResp
+  io.resp.valid     := cmd.valid && doResp
+  io.resp.bits.rd   := rd
+  io.resp.bits.data := rs1
+  // io.resp.bits.data := respData
+
+  // Status
+  io.busy      := cmd.valid && stallResp  // busy only if we're holding a response
+  io.interrupt := false.B
+}
