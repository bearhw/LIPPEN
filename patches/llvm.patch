           (SRLI (SLLI GPR:$rs, 32), (ImmSubFrom32 uimm5:$shamt))>;
 }
 
+// Custom-1 opcode (CUSTOM_1 = 0b0101011)
+let Namespace = "RISCV", hasSideEffects = 0, mayLoad = 0, mayStore = 0 in {
+  // rd = prince_sign(rs1 = plaintext, rs2 = modifier)
+  def ROCC_PRINCE_SIGN
+    : RVInstR<0b0000001,                 // funct7 = 1
+              0b111,                     // funct3 = {xd,xs1,xs2} = 111
+              OPC_CUSTOM_1,              // opcode = 0b0101011
+              (outs GPR:$rd),            // rd
+              (ins GPR:$rs1, GPR:$rs2),  // rs1, rs2
+              "rocc_prince_sign",        // asm mnemonic
+              "$rd, $rs1, $rs2">;        // asm operand format
+  
+  // rd = prince_auth(rs1 = ciphertext, rs2 = modifier)
+  def ROCC_PRINCE_AUTH
+    : RVInstR<0b0000000,                 // funct7 = 0
+              0b111,                     // funct3 = 111
+              OPC_CUSTOM_1,              // opcode = 0b0101011
+              (outs GPR:$rd),
+              (ins GPR:$rs1, GPR:$rs2),
+              "rocc_prince_auth",        // asm mnemonic
+              "$rd, $rs1, $rs2">;        // asm operand format
+}
