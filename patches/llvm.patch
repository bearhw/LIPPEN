+static Function *getIntrinsicMaybeOverloaded(Module &M,
+                                             Intrinsic::ID Id,
+                                             Type *OL = nullptr) {
+  if (Intrinsic::isOverloaded(Id)) {
+    SmallVector<Type *, 1> Tys;
+    if (OL)
+      Tys.push_back(OL);
+    return Intrinsic::getDeclaration(&M, Id, Tys);
+  }
+  return Intrinsic::getDeclaration(&M, Id);
+}
+
+namespace {
+
+struct RoccPacReturnPass : PassInfoMixin<RoccPacReturnPass> {
+  PreservedAnalyses run(Module &M, ModuleAnalysisManager &) {
+    // Only RV64.
+    Triple TT(M.getTargetTriple());
+    if (!TT.isRISCV() || M.getDataLayout().getPointerSizeInBits(0) != 64)
+      return PreservedAnalyses::all();
+
+    LLVMContext &Ctx = M.getContext();
+    Type *I32   = Type::getInt32Ty(Ctx);
+    Type *I64   = Type::getInt64Ty(Ctx);
+    Type *PtrTy = PointerType::get(Ctx, 0); // opaque ptr, AS0
+
+    // Hooks (externs unless provided here).
+    // Sign/auth take (i64 addr, i64 modifier). We'll pass modifier = SP value.
+    FunctionCallee PrinceSign =
+        M.getOrInsertFunction("prince_sign",
+                              FunctionType::get(I64, {I64, I64}, false));
+    FunctionCallee PrinceAuth =
+        M.getOrInsertFunction("prince_auth",
+                              FunctionType::get(I64, {I64, I64}, false));
+
+    // returnaddress intrinsic
+    Function *RetAddr =
+        getIntrinsicMaybeOverloaded(M, Intrinsic::returnaddress, PtrTy);
+
+    // read_register intrinsic for i64 (to read SP / x2)
+    Function *ReadReg =
+        getIntrinsicMaybeOverloaded(M, Intrinsic::read_register, I64);
+
+    bool Changed = false;
+
+    for (Function &F : M) {
+      if (F.isDeclaration())
+        continue;
+
+      // Skip our hooks to avoid recursion, and anything in the pac runtime.
+      StringRef N = F.getName();
+      if (N.startswith("prince_sign") || N.startswith("prince_auth") ||
+          N.startswith("pac_set_key") || N.startswith("__pac_"))
+        continue;
+
+      // Collect rets.
+      SmallVector<ReturnInst *, 8> Rets;
+      for (BasicBlock &BB : F)
+        if (auto *RI = dyn_cast<ReturnInst>(BB.getTerminator()))
+          Rets.push_back(RI);
+      if (Rets.empty())
+        continue;
+
+      // Entry: RA := returnaddress(0); Signed := prince_sign(RA, sp)
+      Instruction *IP =
+          F.getEntryBlock().getFirstNonPHIOrDbgOrLifetime();
+      IRBuilder<> BE(IP);
+
+      // returnaddress(0) -> i64
+      Value *Level0 = ConstantInt::get(I32, 0);
+      Value *RAptr  = BE.CreateCall(RetAddr, {Level0}, "ra.ptr");
+      Value *RAi64  = BE.CreatePtrToInt(RAptr, I64, "ra.i64");
+
+      // Read the hardware stack pointer (x2 == sp) as modifier:
+      //   llvm.read_register.i64(metadata !{!"sp"})
+      MDString *SpStr = MDString::get(Ctx, "sp");
+      MDNode   *SpNode = MDNode::get(Ctx, SpStr);
+      Value    *SpMDVal = MetadataAsValue::get(Ctx, SpNode);
+
+      Value *SpVal =
+          BE.CreateCall(ReadReg, {SpMDVal}, "sp.i64");
+
+      // Keep the signed tag in SSA so we reuse it at returns.
+      // Signed := prince_sign(RA, sp)
+      Value *Signed =
+          BE.CreateCall(PrinceSign, {RAi64, SpVal}, "pac.ra.signed");
+
+      // Each ret: prince_auth(Signed, sp)
+      for (ReturnInst *RI : Rets) {
+        IRBuilder<> BR(RI);
+        (void)BR.CreateCall(PrinceAuth, {Signed, SpVal}, "pac.ra.authed");
+        // No store, no compare — truly minimal
+      }
+
+      Changed = true;
+    }
+
+    return Changed ? PreservedAnalyses::none() : PreservedAnalyses::all();
+  }
+};
