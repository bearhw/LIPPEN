+++ b/llvm/lib/Target/RISCV/MIRSetRAPass.cpp
@@ -0,0 +1,210 @@
+//===-- MIRSetRAPass.cpp ----------------------------------------*- C++ -*-===//
+//
+// RISC-V MIR pass: before a function returns, load RA from a per-function,
+// TU-local shadow global: __pac_ra_shadow$<Function>.
+//
+// Constraints:
+//   - Runs post-PEI (wire in RISCVPassConfig::addPreEmitPass2()).
+//   - DO NOT create new vregs (use physical scratch t0 = X5).
+//   - Emit real LUI+ADDI with %hi/%lo (no %pcrel_* pairing needed).
+//   - RV64 only (we emit LD).
+//
+// Exposes:
+//   • New-PM key: "mir-set-ra"   (llc --passes=mir-set-ra ...)
+//   • Legacy factory: createMIRSetRAPass() (for RISCVPassConfig)
+//
+//===----------------------------------------------------------------------===//
+
+#include "RISCV.h"
+#include "RISCVInstrInfo.h"
+#include "RISCVRegisterInfo.h"
+#include "RISCVSubtarget.h"
+#include "MCTargetDesc/RISCVBaseInfo.h"
+
+#include "llvm/ADT/SmallVector.h"
+#include "llvm/CodeGen/MachineBasicBlock.h"
+#include "llvm/CodeGen/MachineFunction.h"
+#include "llvm/CodeGen/MachineInstrBuilder.h"
+#include "llvm/CodeGen/MachinePassManager.h"     // New-PM MFPM
+#include "llvm/CodeGen/MachineFunctionPass.h"    // Legacy shim
+#include "llvm/IR/Function.h"
+#include "llvm/IR/GlobalVariable.h"
+#include "llvm/IR/Module.h"
+#include "llvm/Pass.h"                           // INITIALIZE_PASS
+#include "llvm/Passes/PassBuilder.h"
+#include "llvm/Support/Debug.h"
+#include "llvm/Support/raw_ostream.h"
+
+#define DEBUG_TYPE "mir-set-ra"
+
+using namespace llvm;
+
+namespace {
+
+// -------------------------------------------------------------------
+// Helpers / core transform
+// -------------------------------------------------------------------
+
+static bool isReturnMI(const MachineInstr &MI) {
+  const unsigned Opc = MI.getOpcode();
+
+  // Most common at isel time: PseudoRET
+  if (Opc == RISCV::PseudoRET)
+    return true;
+
+  // Fallback: canonical JALR x0, x1, 0
+  if (Opc == RISCV::JALR) {
+    if (MI.getNumOperands() >= 3 &&
+        MI.getOperand(0).isReg() && MI.getOperand(1).isReg() &&
+        MI.getOperand(2).isImm()) {
+      const Register RD  = MI.getOperand(0).getReg();
+      const Register RS1 = MI.getOperand(1).getReg();
+      const int64_t Off  = MI.getOperand(2).getImm();
+      return RD == RISCV::X0 && RS1 == RISCV::X1 && Off == 0;
+    }
+  }
+  return false;
+}
+
+// Insert our load *after* any prior 'ld ra, off(sp)' in the same block.
+static MachineBasicBlock::iterator
+chooseInsertionPoint(MachineBasicBlock &MBB,
+                     MachineBasicBlock::iterator RetIt) {
+  MachineBasicBlock::iterator InsertIt = RetIt;
+  if (RetIt == MBB.begin())
+    return InsertIt;
+
+  for (auto I = std::prev(RetIt); /* stop inside */; --I) {
+    if (I->definesRegister(RISCV::X1)) {
+      InsertIt = std::next(I);
+      break;
+    }
+    if (I == MBB.begin())
+      break;
+  }
+  return InsertIt;
+}
+
+// Core transformation shared by New-PM and legacy shim.
+static bool setRAFromShadow(MachineFunction &MF) {
+  const Function &F = MF.getFunction();
+  const Module *M   = F.getParent();
+  const RISCVSubtarget &STI = MF.getSubtarget<RISCVSubtarget>();
+  const RISCVInstrInfo *TII = STI.getInstrInfo();
+
+  if (!M || !STI.is64Bit())
+    return false; // We emit LD (RV64).
+
+  // TU-local per-function shadow (created by your IR pass).
+  const std::string GVName = ("__pac_ra_shadow$" + F.getName()).str();
+  const GlobalVariable *Shadow =
+      M->getGlobalVariable(GVName, /*AllowInternal=*/true);
+  if (!Shadow) {
+    LLVM_DEBUG(dbgs() << "[mir-set-ra] no shadow for " << F.getName() << "\n");
+    return false;
+  }
+
+  bool Changed = false;
+
+  for (MachineBasicBlock &MBB : MF) {
+    for (auto I = MBB.begin(), E = MBB.end(); I != E; ++I) {
+      MachineInstr &MI = *I;
+      if (!isReturnMI(MI))
+        continue;
+
+      DebugLoc DL = MI.getDebugLoc();
+      auto InsertPt = chooseInsertionPoint(MBB, I);
+
+      // Physical scratch register (t0 = X5) — safe right before ret.
+      Register Tmp = RISCV::X5;
+
+      // LUI Tmp, %hi(__pac_ra_shadow$F)
+      BuildMI(MBB, InsertPt, DL, TII->get(RISCV::LUI), Tmp)
+          .addGlobalAddress(const_cast<GlobalVariable *>(Shadow), 0,
+                            RISCVII::MO_HI);
+
+      // ADDI Tmp, Tmp, %lo(__pac_ra_shadow$F)
+      BuildMI(MBB, InsertPt, DL, TII->get(RISCV::ADDI), Tmp)
+          .addReg(Tmp)
+          .addGlobalAddress(const_cast<GlobalVariable *>(Shadow), 0,
+                            RISCVII::MO_LO);
+
+      // LD ra, 0(Tmp)
+      BuildMI(MBB, InsertPt, DL, TII->get(RISCV::LD), RISCV::X1 /* ra */)
+          .addReg(Tmp)
+          .addImm(0);
+
+      LLVM_DEBUG(dbgs() << "[mir-set-ra] injected LUI/ADDI(%hi/%lo)/LD in "
+                        << F.getName() << "\n");
+      errs() << "[mir-set-ra] patched return in " << F.getName() << "\n";
+      Changed = true;
+    }
+  }
+
+  return Changed;
+}
+
+// -------------------------------------------------------------------
+// New-PM wrapper (for: llc --passes=mir-set-ra ...)
+// -------------------------------------------------------------------
+
+struct MIRSetRAPassNewPM : PassInfoMixin<MIRSetRAPassNewPM> {
+  PreservedAnalyses run(MachineFunction &MF,
+                        MachineFunctionAnalysisManager &) {
+    errs() << "[mir-set-ra] (new-PM) running on " << MF.getName() << "\n";
+    bool Changed = setRAFromShadow(MF);
+    return Changed ? PreservedAnalyses::none() : PreservedAnalyses::all();
+  }
+};
+
+} // end anonymous namespace
+
+// New-PM registration: pipeline key "mir-set-ra".
+namespace llvm {
+void registerMirSetRAPassCallbacks(PassBuilder &PB) {
+  PB.registerPipelineParsingCallback(
+      [](StringRef Name, MachineFunctionPassManager &MFPM) {
+        if (Name == "mir-set-ra") {
+          MFPM.addPass(::MIRSetRAPassNewPM());
+          return true;
+        }
+        return false;
+      });
+}
+} // namespace llvm
+
+// -------------------------------------------------------------------
+// Legacy shim + factory (so RISCVPassConfig can schedule this pass)
+// -------------------------------------------------------------------
+
+namespace {
+
+struct MIRSetRAPassLegacy : MachineFunctionPass {
+  static char ID;
+  MIRSetRAPassLegacy() : MachineFunctionPass(ID) {}
+
+  StringRef getPassName() const override {
+    return "RISC-V: set RA from __pac_ra_shadow$<F> (legacy shim)";
+  }
+
+  bool runOnMachineFunction(MachineFunction &MF) override {
+    return setRAFromShadow(MF);
+  }
+};
+
+char MIRSetRAPassLegacy::ID = 0;
+
+} // end anonymous namespace
+
+// Older branches require INITIALIZE_PASS at global scope.
+INITIALIZE_PASS(MIRSetRAPassLegacy,
+                "mir-set-ra",
+                "RISC-V: set RA from __pac_ra_shadow$<F> (legacy shim)",
+                false, // CFGOnly
+                false  // isAnalysis
+)
+
+namespace llvm {
+// Factory used by RISCVPassConfig (declared in RISCV.h)
+FunctionPass *createMIRSetRAPass() { return new MIRSetRAPassLegacy(); }
+} // namespace llvm
