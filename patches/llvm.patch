diff --git a/llvm/lib/Transforms/RoccPacLite/RoccPacReturnLitePass.cpp b/llvm/lib/Transforms/RoccPacLite/RoccPacReturnLitePass.cpp
new file mode 100644
index 000000000000..65d83e002684
--- /dev/null
+++ b/llvm/lib/Transforms/RoccPacLite/RoccPacReturnLitePass.cpp
@@ -0,0 +1,129 @@
+// RoccPacReturnLitePass.cpp — LLVM 18+, new-PM, MODULE pass ("rocc-pac-lite")
+// Target: RV64 only
+// For each defined function F:
+//   Entry:   RA := returnaddress(0); Signed := prince_sign(RA, 0)
+//   Each ret:       prince_auth(Signed, 0)
+
+#include "llvm/ADT/SmallVector.h"
+#include "llvm/IR/BasicBlock.h"
+#include "llvm/IR/Constants.h"
+#include "llvm/IR/DerivedTypes.h"
+#include "llvm/IR/Function.h"
+#include "llvm/IR/IRBuilder.h"
+#include "llvm/IR/InstrTypes.h"
+#include "llvm/IR/Instructions.h"
+#include "llvm/IR/IntrinsicInst.h"
+#include "llvm/IR/Intrinsics.h"
+#include "llvm/IR/LLVMContext.h"
+#include "llvm/IR/Module.h"
+#include "llvm/IR/PassManager.h"
+#include "llvm/IR/Type.h"
+#include "llvm/Passes/PassBuilder.h"
+#include "llvm/Passes/PassPlugin.h"
+#include "llvm/Support/raw_ostream.h"
+#include "llvm/TargetParser/Triple.h"
+
+using namespace llvm;
+
+static Function *getIntrinsicMaybeOverloaded(Module &M,
+                                             Intrinsic::ID Id,
+                                             Type *OL = nullptr) {
+  if (Intrinsic::isOverloaded(Id)) {
+    SmallVector<Type *, 1> Tys;
+    if (OL) Tys.push_back(OL);
+    return Intrinsic::getDeclaration(&M, Id, Tys);
+  }
+  return Intrinsic::getDeclaration(&M, Id);
+}
+
+namespace {
+
+struct RoccPacReturnLitePass : PassInfoMixin<RoccPacReturnLitePass> {
+  PreservedAnalyses run(Module &M, ModuleAnalysisManager &) {
+    // Only RV64.
+    Triple TT(M.getTargetTriple());
+    if (!TT.isRISCV() || M.getDataLayout().getPointerSizeInBits(0) != 64)
+      return PreservedAnalyses::all();
+
+    LLVMContext &Ctx = M.getContext();
+    Type *I32   = Type::getInt32Ty(Ctx);
+    Type *I64   = Type::getInt64Ty(Ctx);
+    Type *PtrTy = PointerType::get(Ctx, 0); // opaque ptr, AS0
+
+    // Hooks (externs unless provided here).
+    // Sign/auth take (i64 addr, i64 modifier). We'll pass modifier = 0.
+    FunctionCallee PrinceSign =
+        M.getOrInsertFunction("prince_sign",
+                              FunctionType::get(I64, {I64, I64}, false));
+    FunctionCallee PrinceAuth =
+        M.getOrInsertFunction("prince_auth",
+                              FunctionType::get(I64, {I64, I64}, false));
+
+    // returnaddress intrinsic
+    Function *RetAddr = getIntrinsicMaybeOverloaded(
+        M, Intrinsic::returnaddress, PtrTy);
+
+    bool Changed = false;
+
+    for (Function &F : M) {
+      if (F.isDeclaration()) continue;
+
+      // Skip our hooks to avoid recursion, and anything in the pac runtime.
+      StringRef N = F.getName();
+      if (N.startswith("prince_sign") || N.startswith("prince_auth") ||
+          N.startswith("pac_set_key") || N.startswith("__pac_"))
+        continue;
+
+      // Collect rets.
+      SmallVector<ReturnInst *, 8> Rets;
+      for (BasicBlock &BB : F)
+        if (auto *RI = dyn_cast<ReturnInst>(BB.getTerminator()))
+          Rets.push_back(RI);
+      if (Rets.empty()) continue;
+
+      // Entry: RA := returnaddress(0); Signed := prince_sign(RA, 0)
+      Instruction *IP = F.getEntryBlock().getFirstNonPHIOrDbgOrLifetime();
+      IRBuilder<> BE(IP);
+
+      Value *Level0 = ConstantInt::get(I32, 0);
+      Value *RAptr  = BE.CreateCall(RetAddr, {Level0}, "ra.ptr");
+      Value *RAi64  = BE.CreatePtrToInt(RAptr, I64, "ra.i64");
+
+      Value *ZeroMod = ConstantInt::get(I64, 0);
+      // Keep the signed tag in SSA so we reuse it at returns.
+      Value *Signed = BE.CreateCall(PrinceSign, {RAi64, ZeroMod}, "pac.ra.signed");
+
+      // Each ret: prince_auth(Signed, 0)
+      for (ReturnInst *RI : Rets) {
+        IRBuilder<> BR(RI);
+        (void)BR.CreateCall(PrinceAuth, {Signed, ZeroMod}, "pac.ra.authed");
+        // No store, no compare — truly minimal
+      }
+
+      Changed = true;
+    }
+
+    return Changed ? PreservedAnalyses::none() : PreservedAnalyses::all();
+  }
+};
+
+} // namespace
+
+// Register as "rocc-pac-lite"
+extern "C" LLVM_ATTRIBUTE_WEAK PassPluginLibraryInfo llvmGetPassPluginInfo() {
+  return {
+      LLVM_PLUGIN_API_VERSION,
+      "RoccPacReturnLitePass",
+      "rv64-ra-lite",
+      [](PassBuilder &PB) {
+        PB.registerPipelineParsingCallback(
+            [](StringRef Name, ModulePassManager &MPM,
+               ArrayRef<PassBuilder::PipelineElement>) {
+              if (Name == "rocc-pac-lite") {
+                MPM.addPass(RoccPacReturnLitePass());
+                return true;
+              }
+              return false;
+            });
+      }};
+}
