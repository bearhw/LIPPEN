diff --git a/llvm/lib/Target/RISCV/RISCVRoccPacReturn.cpp b/llvm/lib/Target/RISCV/RISCVRoccPacReturn.cpp
new file mode 100644
index 000000000000..d85fbae5de29
--- /dev/null
+++ b/llvm/lib/Target/RISCV/RISCVRoccPacReturn.cpp
@@ -0,0 +1,477 @@
+
+#include "RISCV.h"
+#include "RISCVSubtarget.h"
+#include "RISCVRegisterInfo.h"
+#include "llvm/CodeGen/MachineFunction.h"
+#include "llvm/CodeGen/MachineFunctionPass.h"
+#include "llvm/CodeGen/MachineInstrBuilder.h"
+#include "llvm/Support/Debug.h"
+#include "llvm/Support/raw_ostream.h"
+#include <set>
+
+using namespace llvm;
+
+#define DEBUG_TYPE "riscv-rocc-pac-ra"
+
+namespace {
+class RoccPacReturnMFPass : public MachineFunctionPass {
+private:
+  // Track which functions we've already instrumented
+  std::set<const MachineFunction*> InstrumentedFunctions;
+  
+public:
+  static char ID;
+  
+  RoccPacReturnMFPass() : MachineFunctionPass(ID) {}
+  
+  StringRef getPassName() const override {
+    return "RISC-V ROCC PAC Return (MachineFunction)";
+  }
+  
+  bool runOnMachineFunction(MachineFunction &MF) override {
+    StringRef Name = MF.getName();
+    if (Name.startswith("prince_") ||
+        Name.startswith("pac_")) {
+      return false;
+    }
+    // Guard: Check if already processed
+    if (InstrumentedFunctions.count(&MF)) {
+      errs() << "GUARD: Skipping already instrumented function: " << MF.getName() << "\n";
+      return false;
+    }
+    
+    errs() << "========================================\n";
+    errs() << "RoccPacReturnMFPass running on: " << MF.getName() << "\n";
+    
+    const RISCVSubtarget &STI = MF.getSubtarget<RISCVSubtarget>();
+    const RISCVInstrInfo *TII = STI.getInstrInfo();
+    
+    if (!STI.is64Bit())
+      return false;
+    
+    bool Changed = false;
+    const unsigned RAReg = RISCV::X1; // ra
+    const unsigned SPReg = RISCV::X0; // sp
+    
+    // --- Check if already instrumented by looking for our instructions ---
+    MachineBasicBlock &EntryMBB = MF.front();
+    for (auto &MI : EntryMBB) {
+      if (MI.getOpcode() == RISCV::ROCC_PRINCE_SIGN) {
+        errs() << "WARNING: Function " << MF.getName() 
+               << " already has ROCC_PRINCE_SIGN! Skipping.\n";
+        errs() << "========================================\n\n";
+        return false;
+      }
+    }
+    
+    // --- 1) Sign RA IMMEDIATELY AFTER the first SP adjustment ---
+    auto InsertPt = EntryMBB.begin();
+    bool FoundSPAdjust = false;
+    
+    while (InsertPt != EntryMBB.end()) {
+      // Look for: addi sp, sp, <offset>
+      // This includes both regular ADDI and compressed C.ADDI16SP
+      if ((InsertPt->getOpcode() == RISCV::ADDI || 
+           InsertPt->getOpcode() == RISCV::C_ADDI16SP) &&
+          InsertPt->getNumOperands() >= 3 &&
+          InsertPt->getOperand(0).isReg() && 
+          InsertPt->getOperand(0).getReg() == RISCV::X2 &&
+          InsertPt->getOperand(1).isReg() &&
+          InsertPt->getOperand(1).getReg() == RISCV::X2) {
+        
+        // Found SP adjustment! Insert IMMEDIATELY after
+        ++InsertPt;
+        FoundSPAdjust = true;
+        
+        errs() << "  Found SP adjustment, inserting SIGN immediately after\n";
+        break;
+      }
+      ++InsertPt;
+    }
+    
+    if (!FoundSPAdjust) {
+      // No stack adjustment found - function might be a leaf with no frame
+      errs() << "  No SP adjustment found, skipping function\n";
+      errs() << "========================================\n\n";
+      return false;
+    }
+    
+    DebugLoc DL;
+    if (InsertPt != EntryMBB.end())
+      DL = InsertPt->getDebugLoc();
+    else if (InsertPt != EntryMBB.begin())
+      DL = std::prev(InsertPt)->getDebugLoc();
+    
+    errs() << "Inserting ROCC_PRINCE_SIGN at entry (after SP adjust)\n";
+    
+    // ra := prince_sign(ra, sp)
+    // SP now has its adjusted value
+    BuildMI(EntryMBB, InsertPt, DL, TII->get(RISCV::ROCC_PRINCE_SIGN))
+        .addReg(RAReg, RegState::Define)
+        .addReg(RAReg)
+        .addReg(SPReg);
+    Changed = true;
+    
+    // --- 2) Authenticate RA IMMEDIATELY BEFORE SP restoration ---
+    int returnCount = 0;
+    
+    for (auto &MBB : MF) {
+      for (auto MI = MBB.begin(), ME = MBB.end(); MI != ME; ++MI) {
+        if (!MI->isReturn())
+          continue;
+        
+        returnCount++;
+        
+        // Walk backwards from return to find the SP restoration
+        auto SearchPt = MI;
+        bool FoundSPRestore = false;
+        
+        while (SearchPt != MBB.begin()) {
+          --SearchPt;
+          
+          // Look for: addi sp, sp, <positive offset>
+          // This is the epilogue restoring the stack
+          if ((SearchPt->getOpcode() == RISCV::ADDI ||
+               SearchPt->getOpcode() == RISCV::C_ADDI16SP) &&
+              SearchPt->getNumOperands() >= 3 &&
+              SearchPt->getOperand(0).isReg() && 
+              SearchPt->getOperand(0).getReg() == RISCV::X2 &&
+              SearchPt->getOperand(1).isReg() &&
+              SearchPt->getOperand(1).getReg() == RISCV::X2) {
+            
+            // Found SP restoration! Insert BEFORE this instruction
+            FoundSPRestore = true;
+            
+            errs() << "  Found SP restoration before return #" << returnCount 
+                   << ", inserting AUTH immediately before\n";
+            break;
+          }
+        }
+        
+        if (!FoundSPRestore) {
+          // No SP restoration found - might be a tail call or unusual epilogue
+          errs() << "  WARNING: No SP restoration found for return #" << returnCount 
+                 << ", skipping AUTH\n";
+          continue;
+        }
+        
+        DebugLoc RDL = SearchPt->getDebugLoc();
+        
+        errs() << "Inserting ROCC_PRINCE_AUTH before return #" << returnCount 
+               << " (before SP restore)\n";
+        
+        // ra := prince_auth(ra, sp)
+        // SP still has its adjusted value (before restoration)
+        BuildMI(MBB, SearchPt, RDL, TII->get(RISCV::ROCC_PRINCE_AUTH))
+            .addReg(RAReg, RegState::Define)
+            .addReg(RAReg)
+            .addReg(SPReg);
+        Changed = true;
+      }
+    }
+    
+    errs() << "Total returns found: " << returnCount << "\n";
+    errs() << "========================================\n\n";
+    
+    // Mark as instrumented
+    InstrumentedFunctions.insert(&MF);
+    
+    return Changed;
+  }
+};
+} // end anonymous namespace
+
+char RoccPacReturnMFPass::ID = 0;
+
+FunctionPass *llvm::createRoccPacReturnMFPass() {
+  return new RoccPacReturnMFPass();
+}
